+
+      {/* Overlay for mobile menu */}
+      {mobileMenuOpen && (
+        <div
+          className="hidden max-[760px]:block fixed inset-0 bg-black/50 z-40"
+          onClick={() => setMobileMenuOpen(false)}
+        />
