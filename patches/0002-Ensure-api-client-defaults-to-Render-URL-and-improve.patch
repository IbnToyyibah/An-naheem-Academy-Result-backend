-        <Link className="flex flex-col items-center justify-center gap-1.5 px-0 pb-3 pt-0.5 text-center" to={role === 'admin' ? '/admin' : '/parent'}>
-          <span className="mb-1 grid h-[116px] w-[116px] place-items-center overflow-hidden">
+      {/* Mobile Menu Button */}
