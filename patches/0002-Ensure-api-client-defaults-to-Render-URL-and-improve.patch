+      'flex items-center gap-2.5 rounded-[7px] px-3 py-[11px] font-bold text-[#344054] text-sm transition hover:bg-primary-soft hover:text-primary-dark',
       isActive ? 'bg-primary-soft text-primary-dark' : ''
